rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────────
    // Any authenticated user can read profiles (needed for crew member discovery).
    // Only the owner can write their own profile.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;

      match /drives/{driveId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // ── Invites (connection requests) ──────────────────────────────────────────
    match /invites/{inviteId} {
      allow read: if request.auth != null &&
                     (request.auth.uid == resource.data.fromUid ||
                      request.auth.uid == resource.data.toUid);
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
                       (request.auth.uid == resource.data.toUid ||
                        request.auth.uid == resource.data.fromUid);
      allow delete: if request.auth != null &&
                       (request.auth.uid == resource.data.fromUid ||
                        request.auth.uid == resource.data.toUid);
    }

    // ── Crew Invites ───────────────────────────────────────────────────────────
    // One invite per person per crew: document ID is always "{crewId}_{toUid}".
    // This gives a natural uniqueness guarantee — a second write to the same
    // crewId+toUid combo is an update on the same doc, not a new create.
    match /crewInvites/{inviteId} {
      allow read: if request.auth != null &&
                     (request.auth.uid == resource.data.fromUid ||
                      request.auth.uid == resource.data.toUid);
      // Enforce deterministic ID pattern and that the sender is authenticated.
      allow create: if request.auth != null &&
                       request.auth.uid == request.resource.data.fromUid &&
                       inviteId == request.resource.data.crewId + '_' + request.resource.data.toUid;
      allow update: if request.auth != null &&
                       (request.auth.uid == resource.data.toUid ||
                        request.auth.uid == resource.data.fromUid);
      allow delete: if request.auth != null &&
                       (request.auth.uid == resource.data.fromUid ||
                        request.auth.uid == resource.data.toUid);
    }

    // ── Crews ──────────────────────────────────────────────────────────────────
    // Only members can read or update a crew.
    // A non-member can add themselves to members (only that field) to accept an invite.
    // Creator can delete.
    match /crews/{crewId} {
      allow read: if request.auth != null &&
                     request.auth.uid in resource.data.members;
      allow create: if request.auth != null &&
                       request.auth.uid in request.resource.data.members;
      allow update: if request.auth != null && (
                       // Current members can update anything
                       request.auth.uid in resource.data.members
                       ||
                       // Non-member accepting invite: can only add themselves to members
                       (
                         request.auth.uid in request.resource.data.members &&
                         !(request.auth.uid in resource.data.members) &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
                       )
                     );
      allow delete: if request.auth != null &&
                       request.auth.uid == resource.data.createdBy;

      // Presence subcollection: members can read, users write only their own doc.
      match /presence/{presenceUid} {
        allow read: if request.auth != null &&
                       request.auth.uid in
                       get(/databases/$(database)/documents/crews/$(crewId)).data.members;
        allow write: if request.auth.uid == presenceUid;
      }
    }
  }
}
