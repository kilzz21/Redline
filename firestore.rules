rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────────
    // Any authenticated user can read profiles (needed for crew member discovery).
    // Only the owner can write their own profile.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;

      match /drives/{driveId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // ── Invites ────────────────────────────────────────────────────────────────
    match /invites/{inviteId} {
      allow read: if request.auth != null &&
                     (request.auth.uid == resource.data.fromUid ||
                      request.auth.uid == resource.data.toUid);
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
                       (request.auth.uid == resource.data.toUid ||
                        request.auth.uid == resource.data.fromUid);
      allow delete: if request.auth != null &&
                       (request.auth.uid == resource.data.fromUid ||
                        request.auth.uid == resource.data.toUid);
    }

    // ── Crews ──────────────────────────────────────────────────────────────────
    // Only members can read or update a crew.
    // Creator can delete. Channel IDs are Firestore-generated random strings
    // so they are impossible to guess by non-members.
    match /crews/{crewId} {
      allow read: if request.auth != null &&
                     request.auth.uid in resource.data.members;
      allow create: if request.auth != null &&
                       request.auth.uid in request.resource.data.members;
      allow update: if request.auth != null &&
                       request.auth.uid in resource.data.members;
      allow delete: if request.auth != null &&
                       request.auth.uid == resource.data.createdBy;

      // Presence subcollection: members can read, users write only their own doc.
      match /presence/{presenceUid} {
        allow read: if request.auth != null &&
                       request.auth.uid in
                       get(/databases/$(database)/documents/crews/$(crewId)).data.members;
        allow write: if request.auth.uid == presenceUid;
      }
    }
  }
}
